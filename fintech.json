{
  "info": {
    "name": "Fintech Backend API",
    "_postman_id": "c9b3a5f2-1234-4abc-9d88-abcdef123456",
    "description": "Postman collection for Fintech Backend (OTP, JWT, Transactions)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth APIs",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex\",\n  \"email\": \"alex@gmail.com\",\n  \"mobile\": \"9876543210\",\n  \"password\": \"1234\"\n}"
            },
            "url": "{{base_url}}/api/register"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"9876543210\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{base_url}}/api/verify"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@gmail.com\",\n  \"password\": \"1234\"\n}"
            },
            "url": "{{base_url}}/api/login"
          }
        }
      ]
    },
    {
      "name": "Transaction APIs",
      "item": [
        {
          "name": "Transfer Money",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": 1,\n  \"receiverId\": 2,\n  \"amount\": 500\n}"
            },
            "url": "{{base_url}}/api/transfer"
          }
        },
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/transactions/1"
          }
        }
      ]
    }
  ]
}